generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role{
  ADMIN
  CANDIDATE
  RECRUITER
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  firstname      String
  lastname    String
  password String
  role Role @default(CANDIDATE)
  phone String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  skill Skill[]
}

Model Candidate{
  id Int @id @default(autoincrement)

}

Model Skill{
  id Int @id @default(autoincrement())
  name String
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade) 
}
